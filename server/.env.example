# ─────────────────────────────────────────────
# AiCodeReviewer — Server Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# ── Server ────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Atlas Setup ───────────────────────
# Step 1: Go to https://cloud.mongodb.com and sign up (free)
# Step 2: Create a new Project (name it: aicodereviewer)
# Step 3: Create a free M0 cluster (choose any region)
# Step 4: Under Security > Database Access — create a user
#         Username: aicodereviewer
#         Password: (generate a strong password, save it)
# Step 5: Under Security > Network Access — click Add IP Address
#         Choose "Allow access from anywhere" for development (0.0.0.0/0)
# Step 6: Under Deployment > Database — click Connect
#         Choose "Drivers" > Node.js
#         Copy the connection string, it looks like:
#         mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Step 7: Replace <username> and <password> with your values
#         Add your database name before the ? like this:
#         mongodb+srv://aicodereviewer:yourpassword@cluster0.xxxxx.mongodb.net/aicodereviewer?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/aicodereviewer?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────
# Generate a strong secret — run this in terminal:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# ── Client URL (for CORS) ─────────────────────
CLIENT_URL=http://localhost:5173

# ── GitHub API (Phase 3) ──────────────────────
# Get your token from https://github.com/settings/tokens
# Create a Personal Access Token with repo:read scope
GITHUB_TOKEN=your_github_personal_access_token

# ── Groq API (Phase 3) ────────────────────────
# Get your key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key
